# Copy to .env to override the defaults in src/config.ts.
# Admin credentials gating session creation.
# ADMIN_PASSWORD is REQUIRED in production (the server won't boot without it).
# Never commit a real password — set your own value below / via a CI secret.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Admin login token lifetime in minutes (default 720 = 12h).
# ADMIN_TOKEN_TTL_MIN=720

# Other runtime config (defaults shown):
# PORT=1234
# HOST=0.0.0.0
# MAX_USERS_PER_ROOM=2
# NODE_ENV=development
